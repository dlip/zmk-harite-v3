#define MACRO(NAME, BINDINGS) \
        macro_##NAME: macro_##NAME { \
            compatible = "zmk,behavior-macro"; \
            #binding-cells = <0>; \
            wait-ms = <0>; \
            tap-ms = <10>; \
            bindings = <BINDINGS>; \
